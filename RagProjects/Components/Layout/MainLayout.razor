@inherits LayoutComponentBase
@using UiT.RagProjects.Services

<MudThemeProvider Theme="myUI.MyTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudIconButton Icon="@Icons.Material.Filled.MenuOpen" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudImage Alt="The artic University of Norway" Src="/images/uit_en.png" Class="ml-2 mr-8"></MudImage>
        <MudText Class="ml-3" Style="font-size:1.5em;font-weight:500;color:#f5f5f5">@myUI.AppTitle</MudText>
        <MudSpacer />
        <LoginDisplay />
        <ToggleDarkLightMode />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" MiniWidth="40px" ClipMode="DrawerClipMode.Always" Variant="@DrawerVariant.Mini" OpenMiniOnHover="true" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <div style="padding-block-end:180px;">
            <div class="d-block pa-4">@Body</div>
        </div>
    </MudMainContent>
</MudLayout>
@code {
    [Inject] MyUIManager myUI { get; set; } = null!;

    bool _drawerOpen = true;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;

}
