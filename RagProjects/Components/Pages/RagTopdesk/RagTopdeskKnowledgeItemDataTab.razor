@using ChatUiT2.Services
@using ChatUiT2.Interfaces
@using UiT.RestClientTopdesk.Services
@using UiT.RestClientTopdesk.Model
@using ChatUiT2_Classlib.Model.Topdesk

@if(knowledgeItem != null)
{
    <MudGrid Class="mt-1">
        <MudItem xs="2">
            Artikkelnr
        </MudItem>
        <MudItem xs="10">
            @knowledgeItem.Number
        </MudItem>
        <MudItem xs="2">
            Tittel
        </MudItem>
        <MudItem xs="10">
            @knowledgeItem.Translation?.Content?.Title
        </MudItem>
        <MudItem xs="2">
            Description
        </MudItem>
        <MudItem xs="10">
            @knowledgeItem.Translation?.Content?.Description
        </MudItem>
        <MudItem xs="2">
            Content
        </MudItem>
        <MudItem xs="10">
            @knowledgeItem.Translation?.Content?.Content
        </MudItem>
    </MudGrid>
} else {
    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
}

@code {
    [Inject] private IKnowledgeItemService knowledgeItemService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; }

    [Parameter]
    public string? TopdeskId { get; set; }

    private KnowledgeItem? knowledgeItem;
    private bool isLoading = true;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadKnowledgeItemFromTopdesk();
            }
            catch (Exception e)
            {
                Snackbar.Add($"Noe feilet ved lasting av data fra topdesk {e.Message}", Severity.Error, config => { });
            }
        }
    }

    private async Task LoadKnowledgeItemFromTopdesk()
    {
        isLoading = true;
        StateHasChanged();
        knowledgeItem = await knowledgeItemService.GetById(TopdeskId);
        isLoading = false;
        StateHasChanged();
    }
}