@using ChatUiT2_Classlib.Model.RagProject

<MudGrid Class="mt-1">
    <MudItem xs="2">
        Navn
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Name
    </MudItem>
    <MudItem xs="2">
        Beskrivelse
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Description
    </MudItem>
    <MudItem xs="2">
        Opprettet
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Created
    </MudItem>
    <MudItem xs="2">
        Sist oppdatert
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Updated
    </MudItem>
    <MudItem xs="2">
        Rag database navn
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Configuration?.DbName
    </MudItem>
    <MudItem xs="2">
        Item collection name
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Configuration?.ItemCollectionName
    </MudItem>
    <MudItem xs="2">
        Embedding collection name
    </MudItem>
    <MudItem xs="10">
        @RagProject?.Configuration?.EmbeddingCollectioName
    </MudItem>
</MudGrid>

@code {
    [Inject] ISnackbar Snackbar { get; set; } = null!;

    [Parameter]
    public RagProject? RagProject { get; set; }
}