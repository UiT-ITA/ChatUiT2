@page "/ragtopdesk/topdesk-embedding-list"
@using ChatUiT2.Services
@using ChatUiT2.Interfaces
@using UiT.RestClientTopdesk.Services
@using UiT.RestClientTopdesk.Model
@using ChatUiT2_Classlib.Model.Topdesk
@using RagProjects.Model

<PageTitle>Topdesk embeddings</PageTitle>

<MudText Typo="Typo.h3">
    Liste over embeddings for knowledge items fra topdesk som finnes i rag database
</MudText>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudText Typo="Typo.h6">Filtere</MudText>
    <MudGrid Class="mt-1">
        <MudItem xs="12">
            <MudTextField T="string"
                          @bind-Value="titleSearch"
                          Immediate="true"
                          Placeholder="Tittel"
                          Adornment="Adornment.Start"
                          IconSize="Size.Medium"
                          Class="mt-0"
                          OnKeyDown="CheckIfEnterPressed">
            </MudTextField>
        </MudItem>
        <MudItem xs="2">
            <MudIconButton Icon="@Icons.Material.Filled.Search" OnClick="() => DoSearch()"></MudIconButton>
        </MudItem>
        <MudItem xs="10">
        </MudItem>

    </MudGrid>
</MudPaper>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudTable Items="tableKnowledgeItemList"
              T="TopdeskTextEmbeddingViewItem"
              Dense="false"
              Hover="true"
              Bordered="true"
              Striped="true"
              SortLabel="Sort By"
              AllowUnsorted="false"
              Loading="tableIsLoading"
              RowsPerPage="50"
              @ref="table">
        <ToolBarContent>
            <MudText Typo="Typo.h6"></MudText>
            <MudSpacer />
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Nummer_field">Topdesk KI nr</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Tittel_field">Tittel</MudTableSortLabel></MudTh>
            <MudTh>Spørsmål</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @context?.TopdeskKnowledgeItem.Number
            </MudTd>
            <MudTd>
                @context.TopdeskKnowledgeItem?.Title
            </MudTd>
            <MudTd>
                @context.TopdeskTextEmbedding?.Originaltext
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager HorizontalAlignment="HorizontalAlignment.Center" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IRagTopdeskDatabaseService ragTopdeskService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; }

    private List<TopdeskTextEmbeddingViewItem> tableKnowledgeItemList = [];
    private List<TopdeskTextEmbeddingViewItem> allKnowledgeItemsList = [];
    private bool tableIsLoading = true;
    private MudTable<TopdeskTextEmbeddingViewItem> table;
    private bool selectAllFlag = false;
    private MudCheckBox<bool> selectAllCheckbox;
    private string titleSearch = string.Empty;

    public class TopdeskTextEmbeddingViewItem
    {
        public TopdeskKnowledgeItem? TopdeskKnowledgeItem { get; set; }
        public TopdeskTextEmbedding? TopdeskTextEmbedding { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadVectorDbTopdeskEmbeddings();
            }
            catch (Exception e)
            {
                Snackbar.Add($"Noe feilet ved lasting av data {e.Message}", Severity.Error, config => { });
            }
        }
    }

    private async Task LoadVectorDbTopdeskEmbeddings()
    {
        var allDbKI = await ragTopdeskService.GetAllTopdeskKnowledgeItems(true);
        foreach(var ki in allDbKI)
        {
            foreach(var embedding in ki.Embeddings)
            {
                allKnowledgeItemsList.Add(new TopdeskTextEmbeddingViewItem
                {
                    TopdeskKnowledgeItem = ki,
                    TopdeskTextEmbedding = embedding
                });
            }
        }
        await DoSearch();
    }

    private async Task CheckIfEnterPressed(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Call your function here
            await DoSearch();
        }
    }

    private async Task DoSearch()
    {
        tableIsLoading = true;
        tableKnowledgeItemList = [];

        IQueryable<TopdeskTextEmbeddingViewItem>? query = allKnowledgeItemsList.AsQueryable();
        if (query == null)
        {
            Snackbar.Add("Fant ingen artikler", Severity.Info, config => { });
            tableIsLoading = false;
            return;
        }

        if (string.IsNullOrEmpty(titleSearch) == false)
        {
            query = query?.Where(x => x.TopdeskKnowledgeItem.Title != null &&
                                        x.TopdeskKnowledgeItem.Title.Contains(titleSearch, StringComparison.OrdinalIgnoreCase));
        }
        foreach (var item in query.ToList())
        {
            tableKnowledgeItemList.Add(item);
        }
        tableIsLoading = false;
        StateHasChanged();
    }


}