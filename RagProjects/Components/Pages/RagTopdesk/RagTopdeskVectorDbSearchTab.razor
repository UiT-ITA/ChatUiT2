@using ChatUiT2.Interfaces
@using ChatUiT2_Classlib.Model.Topdesk
@using ChatUiT2.Models
@using System.Text.Json
@using UiT.RestClientTopdesk.Services
@using UiT.RestClientTopdesk.Model
@using RagProjects.Model
@using System.Numerics.Tensors

<MudTextField T="string"
              @bind-Value="searchTerm"
              Immediate="true"
              Placeholder="Søk"
              Adornment="Adornment.Start"
              IconSize="Size.Medium"
              Class="mt-0">
</MudTextField>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Search" Class="mt-4">Søk</MudButton>

<MudTable Items="embeddings"
          T="TopdeskTextEmbeddingViewItem"
          Dense="false"
          Hover="true"
          Bordered="true"
          Striped="true"
          SortLabel="Sort By"
          AllowUnsorted="false"
          Loading="isLoading"
          RowsPerPage="50"
          @ref="table">
    <ToolBarContent>
        <MudText Typo="Typo.h6"></MudText>
        <MudSpacer />
    </ToolBarContent>
    <HeaderContent>
        <MudTh><MudTableSortLabel T="TopdeskTextEmbeddingViewItem" SortLabel="Nummer_field">Text</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel T="TopdeskTextEmbeddingViewItem" SortLabel="Nummer_field">Score</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.TopdeskTextEmbedding?.Originaltext</MudTd>
        <MudTd>@context.MatchScore</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager HorizontalAlignment="HorizontalAlignment.Center" />
    </PagerContent>

</MudTable>

@code {
    [Inject] IRagTopdeskDatabaseService ragTopdeskService { get; set; }
    [Inject] ISnackbar Snackbar { get; set; }
    [Inject] IConfigService configService { get; set; }
    [Inject] IKnowledgeItemService knowledgeItemService { get; set; } = null!;

    [Parameter]
    public string? TopdeskId { get; set; }

    private List<TopdeskTextEmbeddingViewItem> embeddings = [];
    private MudTable<TopdeskTextEmbeddingViewItem> table;
    private KnowledgeItem? knowledgeItem;
    private string searchTerm;

    private bool isLoading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadVectorDbEmbeddings();
                await LoadKnowledgeItemFromTopdesk();
            }
            catch (Exception e)
            {
                Snackbar.Add($"Noe feilet ved lasting av data fra vector database {e.Message}", Severity.Error, config => { });
            }
        }
    }

    private async Task LoadVectorDbEmbeddings()
    {
        isLoading = true;
        embeddings = [];
        StateHasChanged();
        var embeddingsFromDb = await ragTopdeskService.GetEmbeddingsByTopdeskKnowledgeItemId(TopdeskId);
        foreach (var embedding in embeddingsFromDb)
        {
            embeddings.Add(new TopdeskTextEmbeddingViewItem()
            {
                TopdeskTextEmbedding = embedding,
                IsEditing = false
            });
        }
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadKnowledgeItemFromTopdesk()
    {
        isLoading = true;
        StateHasChanged();
        knowledgeItem = await knowledgeItemService.GetById(TopdeskId);
        isLoading = false;
        StateHasChanged();
    }

    private async Task Search()
    {
        isLoading = true;
        var userPhraseEmbedding = await ragTopdeskService.GetEmbeddingForText(searchTerm);

        foreach(var embedding in embeddings)
        {
            var floatsUser = userPhraseEmbedding.ToFloats().ToArray();
            var floatsText = embedding.TopdeskTextEmbedding.Embedding;
            if(floatsUser != null &&
               floatsText != null &&
               floatsUser.Length == floatsText.Length)
            embedding.MatchScore = TensorPrimitives.CosineSimilarity(floatsUser, floatsText);
        }

        embeddings = embeddings.OrderByDescending(e => e.MatchScore).ToList();
        isLoading = false;
        StateHasChanged();
    }
}