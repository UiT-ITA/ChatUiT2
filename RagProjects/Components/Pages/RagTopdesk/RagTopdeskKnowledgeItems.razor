@page "/ragtopdesk/topdesk-article-list"
@using ChatUiT2.Services
@using ChatUiT2.Interfaces
@using UiT.RestClientTopdesk.Services
@using UiT.RestClientTopdesk.Model
@using ChatUiT2_Classlib.Model.Topdesk
@using RagProjects.Model
<PageTitle>Topdesk knowledge items</PageTitle>

<MudText Typo="Typo.h3">
    Liste over knowledge items som finnes i topdesk
</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="AddAllToDb" >Add all to rag database</MudButton>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudText Typo="Typo.h6">Filtere</MudText>
    <MudGrid Class="mt-1">
        <MudItem xs="12">
            <MudTextField T="string"
                          @bind-Value="titleSearch"
                          Immediate="true"
                          Placeholder="Tittel"
                          Adornment="Adornment.Start"
                          IconSize="Size.Medium"
                          Class="mt-0"
                          OnKeyDown="CheckIfEnterPressed">
            </MudTextField>
        </MudItem>
        <MudItem xs="12">
            <MudField Label="Vis bare de som er i rag database" Variant="Variant.Outlined" InnerPadding="false">
                <MudRadioGroup T="string" Value="@ShowInVectorDbOnly" ValueChanged="ShowInVectorDbOnlyChanged">
                    <MudRadio Value="@("yes")" Color="Color.Primary">Yes</MudRadio>
                    <MudRadio Value="@("no")" Color="Color.Secondary">No</MudRadio>
                </MudRadioGroup>
            </MudField>
        </MudItem>
        <MudItem xs="2">
            <MudIconButton Icon="@Icons.Material.Filled.Search" OnClick="() => DoSearch()"></MudIconButton>
        </MudItem>
        <MudItem xs="10">
        </MudItem>

    </MudGrid>
</MudPaper>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudTable Items="tableKnowledgeItemList"
              T="KnowledgeItemViewClass"
              Dense="false"
              Hover="true"
              Bordered="true"
              Striped="true"
              SortLabel="Sort By"
              AllowUnsorted="false"
              Loading="tableIsLoading"
              RowsPerPage="50"
              @ref="table">
        <ToolBarContent>
            <MudText Typo="Typo.h6"></MudText>
            <MudSpacer />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                Med i rag
            </MudTh>
            <MudTh>                
            </MudTh>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Nummer_field">Nummer</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Tittel_field">Tittel</MudTableSortLabel></MudTh>
            <MudTh>Finnes i vector db</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudCheckBox T="bool" Value="context.IsInVectorDb" ValueChanged="@((newVal) => SelectCheckboxClicked(context, newVal))"></MudCheckBox>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="@(() => UpdateArticleInRagDb(context))" />
            </MudTd>
            <MudTd DataLabel="Nummer">
                <MudLink Href="@($"/ragtopdesk/{context.KnowledgeItem?.Id}")">
                    @context.KnowledgeItem?.Number
                </MudLink>                
                <MudLink Href="@($"https://uit.topdesk.net/solutions/open-knowledge-items/item/{context.KnowledgeItem?.Number}/{context.KnowledgeItem?.Translation?.Language}/")"
                         Target="_new">
                    <MudIcon Icon="@Icons.Material.Filled.Language" Color="Color.Primary" />
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Content">@context.KnowledgeItem?.Translation?.Content?.Title</MudTd>
            <MudTd DataLabel="Content">
                @if (context.IsInVectorDb)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager HorizontalAlignment="HorizontalAlignment.Center" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IKnowledgeItemService knowledgeItemService { get; set; } = null!;
    [Inject] private IRagTopdeskDatabaseService ragTopdeskService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; }
    [Inject] IConfigService configService { get; set; }

    private List<KnowledgeItemViewClass> tableKnowledgeItemList = [];
    private KnowledgeItemList allKnowledgeItemList = new() { Items = [] };
    private bool tableIsLoading = true;
    private MudTable<KnowledgeItemViewClass> table;
    private bool selectAllFlag = false;
    private MudCheckBox<bool> selectAllCheckbox;
    private List<TopdeskKnowledgeItem> topdeskKnowledgeItemsVectorDb = [];
    private string titleSearch = string.Empty;
    private string ShowInVectorDbOnly = "no";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadVectorDbTopdeskKnowledgeItems();
                await LoadKnowledgeItemsFromTopdesk();
            }
            catch (Exception e)
            {
                Snackbar.Add($"Noe feilet ved lasting av data {e.Message}", Severity.Error, config => { });
            }
        }
    }

    private async Task LoadVectorDbTopdeskKnowledgeItems()
    {
        topdeskKnowledgeItemsVectorDb = await ragTopdeskService.GetAllTopdeskKnowledgeItems();
    }

    private async Task LoadKnowledgeItemsFromTopdesk()
    {
        tableIsLoading = true;
        allKnowledgeItemList = await knowledgeItemService.GetOpen();
        tableKnowledgeItemList = [];
        foreach (var item in allKnowledgeItemList.Items)
        {
            AddKnowledgeItemToViewList(item);
        }
        tableIsLoading = false;
        StateHasChanged();
    }

    private void AddKnowledgeItemToViewList(KnowledgeItem item)
    {
        var vectorDbItem = topdeskKnowledgeItemsVectorDb.FirstOrDefault(x => x.TopdeskId == item.Id);
        bool isUpdated = false;
        if (vectorDbItem != null)
        {
            if (vectorDbItem.Title == item.Translation?.Content?.Title ||
               vectorDbItem.Content == item.Translation?.Content?.Content)
            {
                isUpdated = true;
            }
        }
        tableKnowledgeItemList.Add(new KnowledgeItemViewClass()
        {
            KnowledgeItem = item,
            IsInVectorDb = vectorDbItem == null ? false : true,
            VectorDbInSync = isUpdated
        });
    }

    private async Task SaveKnowledgeItemToMongoDb(KnowledgeItem item)
    {
        var topdeskArticle = await ConvertKnowledgeItemToTopdeskKnowledgeItem(item);
        await ragTopdeskService.SaveTopdeskKnowledgeItem(topdeskArticle);
    }

    private async Task<TopdeskKnowledgeItem> ConvertKnowledgeItemToTopdeskKnowledgeItem(KnowledgeItem item)
    {
        if(item?.Id == null)
        {
            throw new ArgumentException("knowledge item id does not have value");
        }
        // Content of article must be fetched with getById method
        var knowledgeItemWithContent = await knowledgeItemService.GetById(item.Id);

        // Get existing vectorDb document if found
        var existingVectorDbArticle = topdeskKnowledgeItemsVectorDb.FirstOrDefault(x => x.TopdeskId == item.Id);
        if(existingVectorDbArticle == null)
        {
            existingVectorDbArticle = new();
        }
        existingVectorDbArticle.Number = item.Number ?? string.Empty;
        existingVectorDbArticle.Title = item.Translation?.Content?.Title ?? string.Empty;
        existingVectorDbArticle.TopdeskId = item.Id;
        existingVectorDbArticle.Content = knowledgeItemWithContent.Translation?.Content?.Content ?? string.Empty;
        existingVectorDbArticle.Description = item.Translation?.Content?.Description ?? string.Empty;

        return existingVectorDbArticle;
    }

    private async Task CheckIfEnterPressed(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Call your function here
            await DoSearch();
        }
    }

    private async Task DoSearch()
    {
        tableIsLoading = true;
        tableKnowledgeItemList = [];

        IQueryable<KnowledgeItem>? query = allKnowledgeItemList.Items?.AsQueryable();
        if(query == null)
        {
            Snackbar.Add("Fant ingen artikler", Severity.Info, config => { });
            tableIsLoading = false;
            return;
        }
        if (ShowInVectorDbOnly == "yes")
        {
            query = query?.Where(x => topdeskKnowledgeItemsVectorDb.Any(y => y.TopdeskId == x.Id));
        }

        if(string.IsNullOrEmpty(titleSearch) == false)
        {
            query = query?.Where(x => x.Translation != null &&
                                        x.Translation.Content != null &&
                                        x.Translation.Content.Title != null &&
                                        x.Translation.Content.Title.Contains(titleSearch, StringComparison.OrdinalIgnoreCase));
        }
        foreach (var item in query.ToList())
        {
            AddKnowledgeItemToViewList(item);
        }
        tableIsLoading = false;
        StateHasChanged();
    }

    private async Task SelectCheckboxClicked(KnowledgeItemViewClass item, bool newValue)
    {
        item.IsInVectorDb = newValue;
        await UpdateArticleInRagDb(item);
        StateHasChanged();
    }

    private async Task UpdateArticleInRagDb(KnowledgeItemViewClass item)
    {
        try
        {
            await ragTopdeskService.SaveTopdeskKnowledgeItem(await ConvertKnowledgeItemToTopdeskKnowledgeItem(item.KnowledgeItem!));
            Snackbar.Add("Artikkel lagret i RAG database", Severity.Success, config => { });
        }
        catch (Exception e)
        {
            Snackbar.Add($"Noe feilet ved lagring av artikkel i RAG database {e.Message}", Severity.Error, config => { });
        }
    }

    private async Task ShowInVectorDbOnlyChanged(string value)
    {
        ShowInVectorDbOnly = value;
        if (table != null) await table.ReloadServerData();
    }

    /// <summary>
    /// Adds all knowledge items not already in rag database to rag database.
    /// </summary>
    /// <returns></returns>
    private async Task AddAllToDb()
    {
        try
        {
            var existingTopdeskIds = await ragTopdeskService.GetAllTopdeskKnowledgeItems(true);
            foreach (var item in tableKnowledgeItemList)
            {
                var knowledgeItemFull = await knowledgeItemService.GetById(item.KnowledgeItem.Id);
                // Skip articles with less than 200 characters
                if (knowledgeItemFull.Translation.Content.Content.Length < 200)
                {
                    continue;
                }
                var existingItem = existingTopdeskIds.FirstOrDefault(x => x.TopdeskId == item.KnowledgeItem.Id);
                if (existingItem == null)
                {
                    await SaveKnowledgeItemToMongoDb(item.KnowledgeItem!);
                    await GenerateQuestionsFromContent(knowledgeItemFull);
                } else
                {
                    string t1 = "";
                }
            }
            Snackbar.Add("Alle artikler lagret i RAG database", Severity.Success, config => { });
        }
        catch (Exception e)
        {
            Snackbar.Add($"Noe feilet ved lagring av artikler i RAG database {e.Message}", Severity.Error, config => { });
        }
    }

    private async Task GenerateQuestionsFromContent(KnowledgeItem item)
    {
        try
        {

            var questionsFromLlm = await ragTopdeskService.GenerateQuestionsFromContent(item.Translation.Content.Content);
            if (questionsFromLlm != null)
            {
                foreach (var question in questionsFromLlm.Questions)
                {
                    await AddTopdeskTextEmbedding(item.Id, question);
                }
            }
            else
            {
                Snackbar.Add($"Fikk ingen spørsmål fra language model", Severity.Error, config => { });
            }
        }
        catch (Exception e)
        {
            Snackbar.Add($"Noe feilet ved generering av spørsmål {e.Message}", Severity.Error, config => { });
        }
    }

    private async Task AddTopdeskTextEmbedding(string topdeskId, string originalText = "")
    {
        try
        {
            TopdeskTextEmbedding newEmbedding = new TopdeskTextEmbedding()
            {
                Model = configService.GetEmbeddingModel().Name,
                ModelProvider = configService.GetEmbeddingModel().DeploymentType,
                Originaltext = originalText,
                TopdeskKnowledgeItemId = topdeskId
            };
            newEmbedding.Embedding = (await ragTopdeskService.GetEmbeddingForText(newEmbedding.Originaltext)).ToFloats().ToArray();
            await ragTopdeskService.SaveTopdeskKnowledgeItemEmbedding(newEmbedding);
        }
        catch (Exception e)
        {
            Snackbar.Add($"Noe feilet ved lagring av embedding {e.Message}", Severity.Error, config => { });
        }
    }
}