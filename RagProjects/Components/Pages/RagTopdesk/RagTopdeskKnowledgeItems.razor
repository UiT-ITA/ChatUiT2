@page "/ragtopdesk/topdesk-article-list"
@using ChatUiT2.Services
@using ChatUiT2.Interfaces
@using UiT.RestClientTopdesk.Services
@using UiT.RestClientTopdesk.Model
@using ChatUiT2_Classlib.Model.Topdesk

<PageTitle>Topdesk knowledge items</PageTitle>

<MudText Typo="Typo.h3">
    Liste over knowledge items som finnes i topdesk
</MudText>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudText Typo="Typo.h6">Filtere</MudText>
    <MudGrid>
        <MudItem xs="2">
            Tittel
        </MudItem>
        <MudItem xs="10">
            <MudTextField T="string"
                          @bind-Value="titleSearch"
                          Immediate="true"
                          Placeholder="Tittel"
                          Adornment="Adornment.Start"
                          IconSize="Size.Medium"
                          Class="mt-0"
                          OnKeyDown="CheckIfEnterPressed">
            </MudTextField>
        </MudItem>
        <MudItem xs="2">
            <MudIconButton Icon="@Icons.Material.Filled.Search" OnClick="() => DoSearch()"></MudIconButton>
        </MudItem>
        <MudItem xs="10">
        </MudItem>

    </MudGrid>
</MudPaper>

<MudPaper Elevation="3" Class="mt-4 pa-4">
    <MudTable Items="tableKnowledgeItemList"
              T="KnowledgeItemViewClass"
              Dense="false"
              Hover="true"
              Bordered="true"
              Striped="true"
              SortLabel="Sort By"
              AllowUnsorted="false"
              Loading="tableIsLoading"
              RowsPerPage="50"
              @ref="table">
        <ToolBarContent>
            <MudText Typo="Typo.h6"></MudText>
            <MudSpacer />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudCheckBox T="bool" Value="selectAllFlag" ValueChanged="@((newVal) => SelectAllCheckboxClicked(newVal))" @ref="selectAllCheckbox"></MudCheckBox>
            </MudTh>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Personnr_field">Nummer</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel T="KnowledgeItem" SortLabel="Fornavn_field">Tittel</MudTableSortLabel></MudTh>
            <MudTh>In vector db</MudTh>
            <MudTh>Vector db needs update</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudCheckBox T="bool" Value="context.IsChecked" ValueChanged="@((newVal) => SelectCheckboxClicked(context, newVal))"></MudCheckBox>
            </MudTd>
            <MudTd DataLabel="Nummer">
                <MudLink Href="@($"https://uit.topdesk.net/solutions/open-knowledge-items/item/{context.KnowledgeItem?.Number}/{context.KnowledgeItem?.Translation?.Language}/")"
                         Target="_new">
                    @context.KnowledgeItem?.Number
                </MudLink>
            </MudTd>
            <MudTd DataLabel="Content">@context.KnowledgeItem?.Translation?.Content?.Title</MudTd>
            <MudTd DataLabel="Content">@context.IsInVectorDb</MudTd>
            <MudTd DataLabel="Content">
                @if (context.VectorDbInSync)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="@(() => UpdateArticleInRagDb(context))" />
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager HorizontalAlignment="HorizontalAlignment.Center" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    [Inject] private IKnowledgeItemService knowledgeItemService { get; set; } = null!;
    [Inject] private IRagTopdeskDatabaseService ragTopdeskService { get; set; } = null!;
    [Inject] ISnackbar Snackbar { get; set; }

    private List<KnowledgeItemViewClass> tableKnowledgeItemList = [];
    private KnowledgeItemList allKnowledgeItemList = new() { Items = [] };
    private bool tableIsLoading = true;
    private MudTable<KnowledgeItemViewClass> table;
    private bool selectAllFlag = false;
    private MudCheckBox<bool> selectAllCheckbox;
    private List<TopdeskArticle> topdeskArticlesVectorDb = [];
    private string titleSearch = string.Empty;

    private class KnowledgeItemViewClass
    {
        public bool IsChecked { get; set; } = false;
        public bool IsInVectorDb { get; set; }
        /// <summary>
        /// True if the article in vector db has same values as the knowledge item
        /// </summary>
        public bool VectorDbInSync { get; set; }
        public KnowledgeItem? KnowledgeItem { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await LoadVectorDbTopdeskArticles();
                await LoadKnowledgeItemsFromTopdesk();
            }
            catch (Exception e)
            {
                Snackbar.Add($"Noe feilet ved lasting av data {e.Message}", Severity.Error, config => { });
            }
        }
    }

    private async Task LoadVectorDbTopdeskArticles()
    {
        topdeskArticlesVectorDb = await ragTopdeskService.GetAllTopdeskArticles();
    }

    private async Task LoadKnowledgeItemsFromTopdesk()
    {
        tableIsLoading = true;
        allKnowledgeItemList = await knowledgeItemService.GetOpen();
        tableKnowledgeItemList = [];
        foreach (var item in allKnowledgeItemList.Items)
        {
            var vectorDbItem = topdeskArticlesVectorDb.FirstOrDefault(x => x.TopdeskId == item.Id);
            bool isUpdated = false;
            if (vectorDbItem != null)
            {
                if(vectorDbItem.Title == item.Translation?.Content?.Title ||
                   vectorDbItem.Content == item.Translation?.Content?.Content)
                {
                    isUpdated = true;
                }
            }
            tableKnowledgeItemList.Add(new KnowledgeItemViewClass()
            {
                KnowledgeItem = item,
                IsInVectorDb = vectorDbItem == null ? false : true,
                VectorDbInSync = isUpdated
            });
        }
        tableIsLoading = false;
        StateHasChanged();
    }

    private async Task SaveKnowledgeItemToMongoDb(KnowledgeItem item)
    {
        var topdeskArticle = await ConvertKnowledgeItemToTopdeskArticle(item);
        await ragTopdeskService.SaveTopdeskArticle(topdeskArticle);
    }

    private async Task<TopdeskArticle> ConvertKnowledgeItemToTopdeskArticle(KnowledgeItem item)
    {
        if(item?.Id == null)
        {
            throw new ArgumentException("knowledge item id does not have value");
        }
        // Content of article must be fetched with getById method
        var knowledgeItemWithContent = await knowledgeItemService.GetById(item.Id);

        // Get existing vectorDb document if found
        var existingVectorDbArticle = topdeskArticlesVectorDb.FirstOrDefault(x => x.TopdeskId == item.Id);
        if(existingVectorDbArticle == null)
        {
            existingVectorDbArticle = new();
        }
        existingVectorDbArticle.Number = item.Number ?? string.Empty;
        existingVectorDbArticle.Title = item.Translation?.Content?.Title ?? string.Empty;
        existingVectorDbArticle.TopdeskId = item.Id;
        existingVectorDbArticle.Content = knowledgeItemWithContent.Translation?.Content?.Content ?? string.Empty;
        existingVectorDbArticle.Description = item.Translation?.Content?.Description ?? string.Empty;

        return existingVectorDbArticle;
    }

    private async Task CheckIfEnterPressed(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            // Call your function here
            await DoSearch();
        }
    }

    private async Task DoSearch()
    {
        tableIsLoading = true;
        tableKnowledgeItemList = [];
        foreach (var item in allKnowledgeItemList.Items?.Where(x => x.Translation?.Content?.Title?.Contains(titleSearch, StringComparison.OrdinalIgnoreCase) ?? false).ToList() ?? [])
        {
            tableKnowledgeItemList.Add(new KnowledgeItemViewClass()
            {
                KnowledgeItem = item
            });
        }
        tableIsLoading = false;
        StateHasChanged();
    }

    private async Task SelectAllCheckboxClicked(bool newValue)
    {
        selectAllFlag = newValue;
        foreach (var item in tableKnowledgeItemList)
        {
            item.IsChecked = newValue;
        }
        StateHasChanged();
    }

    private async Task SelectCheckboxClicked(KnowledgeItemViewClass item, bool newValue)
    {
        item.IsChecked = newValue;
        await UpdateArticleInRagDb(item);
        StateHasChanged();
    }

    private async Task UpdateArticleInRagDb(KnowledgeItemViewClass item)
    {
        try
        {
            await ragTopdeskService.SaveTopdeskArticle(await ConvertKnowledgeItemToTopdeskArticle(item.KnowledgeItem!));
            Snackbar.Add("Artikkel lagret i RAG database", Severity.Success, config => { });
        }
        catch (Exception e)
        {
            Snackbar.Add($"Noe feilet ved lagring av artikkel i RAG database {e.Message}", Severity.Error, config => { });
        }
    }
}