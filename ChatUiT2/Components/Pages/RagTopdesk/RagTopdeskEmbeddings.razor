@page "/ragtopdesk"
@using ChatUiT2.Services

<PageTitle>Test embeddings</PageTitle>

<MudText Typo="Typo.h3">Test embeddings</MudText>

@if (ragProject != null)
{
<MudExpansionPanels Class="mt-4">
    <MudExpansionPanel Text="Paste text" MaxHeight="600" Expanded="false">
        <MudTextField @bind-Value="userPastedTextNumQuestions" Label="Num terms to create" />
        <MudTextField @bind-Value="userPastedTextUrl" Label="Url to source" />
        <MudTextField T="string" Label="Text to create phrases for" Variant="Variant.Text" @bind-Text="@userPastedText" Lines="5" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreatePhrasesFromPastedText" Class="mt-4">Generate search phrases</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateQuestionsFromPastedText" Class="mt-4">Generate questions</MudButton>
    </MudExpansionPanel>
    <MudExpansionPanel Text="Db tools" MaxHeight="200" Expanded="false">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="DeleteAllProjectEmbeddings" Class="mt-4">Db del all documents</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateVectorIndex" Class="mt-4">Db cr vector index</MudButton>
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
        [Inject] private IAuthUserService Auth { get; set; } = null!;
        [Inject] private IUserService UserService { get; set; } = null!;
        [Inject] private NavigationManager Nav { get; set; } = null!;
        [Inject] private ILogger<Admin> Logger { get; set; } = null!;

    private string userPhrase = string.Empty;
    private string userPastedText = string.Empty;
    private int userPastedTextNumQuestions = 10;
    private string userPastedTextUrl = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
        }
    }

    private async Task CreatePhrasesFromPastedText()
    {
        IList<ChatMessage> messages = [];
        string systemMessage = $"Using the input about a study course provided by user, generate {userPastedTextNumQuestions} search terms a person may have used that should give the course as result. Return only a json string that is a list of strings with the search terms. Omit ```json and ``` from response. Json should be an object with property Searchterms that is the list of strings. Example json: {{ \"Searchterms\" : [ \"searchterm1\", \"searchterm2\" ] }} ";

        messages.Add(
            new()
            {
                Role = ChatMessageRole.System,
                Content = systemMessage
            }
        );
        messages.Add(
            new()
            {
                Role = ChatMessageRole.User,
                Content = userPastedText
            }
        );
        var result = await llmChatClient.CompleteAsync(messages);
        var terms = JsonSerializer.Deserialize<SearchtermsFromTextResult>(result.Message.Text);
        foreach (var term in terms.Searchterms)
        {
            AddTextToEmbed(term);
        }
        StateHasChanged();
    }
}
