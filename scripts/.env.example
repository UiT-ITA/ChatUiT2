# Copy this file to ".env" (in this scripts folder) to point the maintenance
# scripts at a specific database - e.g. PRODUCTION - instead of the app's
# local .NET user secrets.
#
# ".env" is gitignored. NEVER commit a real connection string.
#
# Precedence used by the scripts:
#   1. an explicit -ConnectionString argument
#   2. this .env file (if present)
#   3. the app's .NET user secrets (ConnectionStrings:MongoDb)
#
# Provide the connection string under any one of these keys (first match wins):
#   ConnectionStrings__MongoDb, MongoDb, MONGODB_CONNECTION_STRING, MONGODB_URI, ConnectionString

ConnectionStrings__MongoDb=mongodb://<account>:<primary-key>@<account>.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false&maxIdleTimeMS=120000&appName=@<account>@
